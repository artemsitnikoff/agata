# ── Telethon userbot (личный аккаунт, от которого пишем боту) ──────────────
# По умолчанию используется личное Telegram-приложение (можно переопределить).
TELETHON_API_ID=33988209
TELETHON_API_HASH=e88485f4f18cd2bee1f8552c655a9893
# StringSession — сгенерировать локально: python gen_session.py
TELETHON_SESSION=

# ── Целевой бот ─────────────────────────────────────────────────────────────
TARGET_BOT=@zeta963cy3c_bot

# ── Поведение «спросить бота» ───────────────────────────────────────────────
ASK_TIMEOUT=60
ASK_COLLECT_SECONDS=3
# Бот шлёт «идёт поиск… подождите» и затем РЕДАКТИРУЕТ его результатом —
# сколько ждать эту правку/финальный ответ, сек.
ASK_EDIT_TIMEOUT=30

# ── Безопасность API ────────────────────────────────────────────────────────
# Общий секрет для заголовка X-API-Token. Пусто = без аутентификации (только dev!).
API_TOKEN=

# ── Пасхалка «ситников» (Аве, Цезарь! + Сенека). true/false ─────────────────
ENABLE_SENECA=true
